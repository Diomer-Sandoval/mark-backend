DJANGO_SECRET_KEY=django-insecure-change-this-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DEV_MODE_ALLOW_UNAUTHENTICATED=False
OPENAI_API_KEY=sk-your-openai-api-key-here
SIA_BASE_URL=http://127.0.0.1:8001
SIA_FRONTEND_URL=http://localhost:3000
SIA_JWT_SECRET=
SIA_OAUTH_CLIENT_ID=mark-agent
SIA_OAUTH_CLIENT_SECRET=your-oauth-client-secret-from-sia
FRONTEND_URL=http://localhost:5174
OAUTH_ERROR_PATH=/auth/error
OAUTH_INCLUDE_USER_INFO=False
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000,http://127.0.0.1:5174,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True
SESSION_COOKIE_AGE=3600
LOG_LEVEL=INFO
