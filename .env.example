# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-django-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here

# ── LangChain / LangSmith ─────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=mark-backend

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_IMAGE_API_KEY=your-gemini-image-api-key-here

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── Firebase ──────────────────────────────────────────────────────────────────
# Paste the full service account JSON as a single line, or set GOOGLE_APPLICATION_CREDENTIALS
# to the path of the service account JSON file.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── SIA Solutions ─────────────────────────────────────────────────────────────
SIA_BASE_URL=https://sia-backend-sbw7.onrender.com
SIA_JWT_SECRET=
DEV_MODE_ALLOW_UNAUTHENTICATED=False

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
